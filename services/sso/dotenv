# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@mail.com
SMTP_PASSWORD=app_password
FROM_EMAIL=your@mail.com
SMTP_JWT_SECRET=SECRET

# JWT
JWT_SECRET_KEY=SECRET
REFRESH_TOKEN_TTL=7d
ACCESS_TOKEN_TTL=15m

# Cookie
COOKIE_PATH=/
COOKIE_SECURE=true
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=None
COOKIE_MAX_AGE=7d

# gRPC
GRPC_PORT=50051
GRPC_TIMEOUT=24h

# REST
HTTP_PORT=8080
SWAGGER_ENABLED=true
SWAGGER_USER=
SWAGGER_PASSWORD=
SWAGGER_BASE_PATH=/api

