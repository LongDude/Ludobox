# Domain
DOMAIN=localhost
PUBLIC_URL=http://localhost

# Allowed origins (comma-separated)
ALLOWED_REDIRECT_URLS=http://localhost:5173,http://localhost:8080,http://localhost
ALLOWED_CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost
# Default admin emails (comma-separated)
DEFAULT_ADMIN_EMAILS=admin@example.com

# Database
POSTGRES_HOST=sso-postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=db
SSLMode=

# Redis
REDIS_HOST=sso-redis
REDIS_PORT=6379
REDIS_PASSWORD=password
REDIS_DB=0

