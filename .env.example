# Общий файл конфигурации платформы Ludobox
# Для удобства чтения добавлены следущие пометки:
# #*< Optional > - Без указания параметра некоторые функции системы будут недоступны, но система в целом будет работать
# #?< Change > - Не рекомендуется использовать временный параметр из соображений безопасности

COMPOSE_PROJECT_NAME=ludobox

DOMAIN=localhost
PUBLIC_URL=http://localhost
ALLOWED_REDIRECT_URLS=http://localhost:5173,http://localhost:8080,http://localhost
ALLOWED_CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost
DEFAULT_ADMIN_EMAILS=admin@example.com #?< Change >

POSTGRES_SSL=disable
INTERNAL_PROXY_TOKEN=rooms-internal-token #?< Change >

# Настройка общей базы данных для серверной части
SHARED_POSTGRES_USER=postgrya
SHARED_POSTGRES_PASSWORD=pasdbioh312890
SHARED_POSTGRES_DB=ludobox-db

# Настройка базы данных Posgres для SSO
#   SSO спроектирована с возможностью использования как внешний сервис
SSO_POSTGRES_HOST=sso-postgres
SSO_POSTGRES_HOST_PORT=15432
SSO_POSTGRES_USER=postgres #?< Change >
SSO_POSTGRES_PASSWORD=password #?< Change >
SSO_POSTGRES_DB=db

# Настройка Redis
SSO_REDIS_PASSWORD=password #?< Change >
SSO_REDIS_DB=0
GAME_REDIS_PASSWORD=password #?< Change >
GAME_REDIS_DB=0
MATCHMAKING_REDIS_PASSWORD=password #?< Change >
MATCHMAKING_REDIS_DB=0
USER_REDIS_PASSWORD=password #?< Change >
USER_REDIS_DB=0

# Ключ и время жизни JWT токенов
JWT_SECRET_KEY=SECRET #?< Change >
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Параметры SMTP
#   Без настроенной SMTP службы не будет работать регистрация/авторизация по почте
#   На работу OAuth не влияет
SMTP_HOST=smtp.gmail.com #*< Optional >
SMTP_PORT=587
SMTP_USERNAME=user@mail.com #*< Optional >
SMTP_PASSWORD=userpass #*< Optional >
FROM_EMAIL=your@mail.com
SMTP_JWT_SECRET=JWTTOKEN #*< Optional >

COOKIE_PATH=/
COOKIE_SECURE=true
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=Lax
COOKIE_MAX_AGE=7d

# Параметры swagger
#   При указании User/Password включается авторизация по протоколу HTTPBasic
#   Иначе страница публично доступна 
SWAGGER_ENABLED=true
SWAGGER_USER= #*< Optional >
SWAGGER_PASSWORD= #*< Optional >

SSO_HTTP_PORT=8080
SSO_GRPC_PORT=50051
SSO_GRPC_TIMEOUT=24h
SSO_SWAGGER_BASE_PATH=/api

GAME_SERVER_HTTP_PORT=8080
GAME_SERVER_SWAGGER_BASE_PATH=/api/game
GAME_SERVER_HEARTBEAT_INTERVAL=5s

MATCHMAKING_HTTP_PORT=8080
MATCHMAKING_SWAGGER_BASE_PATH=/api/matchmaking
GAME_SERVER_STALE_AFTER=15s
MATCHMAKING_RECOMMENDATION_CACHE_TTL=10s

USER_SERVICE_HTTP_PORT=8080
USER_SERVICE_SWAGGER_BASE_PATH=/api/users
SSO_AUTHENTICATE_URL=http://sso-core:8080/api/auth/authenticate
MATCHMAKING_SELECT_SERVER_URL=http://haproxy:80/__internal/matchmaking/game-servers/next

RNG_STUB_HTTP_PORT=7001
RNG_SERVICE_URL=http://rng-stub:7001/winnings/distribute

# Токены для OAuth через соотвествующие сервисы
GOOGLE_CLIENT_ID= #*< Optional >
GOOGLE_CLIENT_SECRET= #*< Optional >
YANDEX_CLIENT_ID= #*< Optional >
YANDEX_CLIENT_SECRET= #*< Optional >
VK_CLIENT_ID= #*< Optional >
VK_CLIENT_SECRET= #*< Optional >

FRONTEND_DEV_PORT=5173
FRONTEND_PORT=8080
FRONTEND_DEV_BASE_URL=http://localhost:5173
FRONTEND_BASE_URL=http://localhost:8080
VITE_API_BASE_URL=http://localhost/api
VITE_SSO_CLIENT_ID_URL=http://localhost/api

# Параметры для PGAdmin
#   Изменение стандартных параметров рекомендовано в целях безопасности
PGADMIN_PORT=8081
PGADMIN_DEFAULT_EMAIL=pgadmin@mail.com #?< Change >
PGADMIN_DEFAULT_PASSWORD=pgadminpass #?< Change >

REDIS_COMMANDER_GAME_1_PORT=9001
REDIS_COMMANDER_GAME_2_PORT=9002
REDIS_COMMANDER_MATCHMAKING_PORT=9003
REDIS_COMMANDER_USER_PORT=9004
